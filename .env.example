# Supabase Configuration
# Copy this file to .env and fill in your actual values

# Environment (development, staging, production)
ENVIRONMENT=development

# Your Supabase project URL (found in Settings → API → Project URL)
SUPABASE_URL=https://xxxxx.supabase.co

# Your Supabase service_role key (found in Settings → API → Project API keys → service_role)
# WARNING: Keep this secret! Do not commit .env file to git
SUPABASE_KEY=your-service-role-key-here

# Your Supabase anon/public key (found in Settings → API → Project API keys → anon public)
# Safe to expose to the browser — used by the frontend for Realtime subscriptions
SUPABASE_ANON_KEY=your-anon-key-here

# Frontend (Vite) environment variables — passed to the browser build
# VITE_SUPABASE_URL maps to SUPABASE_URL (same value, re-exposed for Vite)
VITE_SUPABASE_URL=https://xxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# T-1001-INFRA: CloudFront CDN Configuration for GLB Files
# CDN_BASE_URL: Base URL for CDN distribution (CloudFront or direct Supabase Storage in dev)
# Default: Supabase Storage URL (direct S3 access, no optimization)
# Production: CloudFront distribution URL (cached, compressed, low-latency)
# Example production: https://d1234abcd.cloudfront.net
CDN_BASE_URL=https://YOUR_PROJECT_REF.supabase.co/storage/v1/object/public/processed-geometry

# USE_CDN: Feature toggle to enable/disable CDN transformation
# false (default): Use S3 URLs directly (development mode, no CDN benefits)
# true: Transform S3 URLs to CDN URLs (production mode, 60% latency reduction)
USE_CDN=false

# PostgreSQL Connection String for direct database access to Supabase
# Found in: Settings → Database → Connection string → URI
# Format: postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres
# IMPORTANT: This is the ONLY database used (no local PostgreSQL)
SUPABASE_DATABASE_URL=postgresql://postgres:your-password@db.xxxxx.supabase.co:5432/postgres

# CORS Configuration (comma-separated, no spaces)
# Development default allows Vite dev server and alternative ports
# Production example: ALLOWED_ORIGINS=https://sf-pm.example.com,https://dashboard.sf-pm.example.com
# SECURITY: Never use "*" with allow_credentials=True in production
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Redis Authentication (docker-compose redis service)
# Generate secure password with: openssl rand -base64 24
# CRITICAL: Required for Celery task queue security
# Note: CELERY_BROKER_URL is built automatically in config.py with URL encoding
REDIS_PASSWORD=your-secure-redis-password-here

# Optional Redis Configuration (override defaults if needed)
# REDIS_HOST=redis        # Default: redis (Docker service name)
# REDIS_PORT=6379         # Default: 6379
# REDIS_DB=0              # Default: 0
# REDIS_URL=redis://...   # Priority 1: Railway auto-injected (already URL-encoded)

# ===== T-1810-INFRA: OpenAI Rate Limiting Configuration =====
# Prevents HTTP 429 errors during batch uploads by limiting API request rate
# Uses token bucket algorithm with Redis backend for distributed rate limiting

# Rate limit: Maximum OpenAI API requests per minute (default: 5)
# Free tier: 3 RPM (use 5 with buffer for safety)
# Tier 1: 500 RPM (can increase to 100+)
# Tier 2: 5000 RPM (can increase to 1000+)
OPENAI_RATE_LIMIT_PER_MIN=5

# Max concurrent LLM requests (default: 3)
# Prevents burst requests that could trigger rate limits
# Free tier: Keep at 3 or lower
# Paid tiers: Can increase based on RPM allocation
OPENAI_MAX_CONCURRENT=3

# Token bucket size: Max tokens that can accumulate (default: same as rate_limit)
# Higher values allow burst processing after idle periods
# Example: OPENAI_RATE_LIMIT_BUCKET_SIZE=10 allows 10 requests burst if bucket full
OPENAI_RATE_LIMIT_BUCKET_SIZE=5

# Rate limiter timeout: Max seconds to wait for token before fallback (default: 30.0)
# If acquire_token() timeout reached → fallback to regex classification
# Increase for patient workflows, decrease for fast-fail behavior
OPENAI_RATE_LIMITER_TIMEOUT=30.0
